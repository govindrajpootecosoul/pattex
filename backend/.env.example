PORT=3026
# Main DB for users (collection: userspattex_emami). Company data lives in DBs like pattex, emami on same cluster.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.2ift0zy.mongodb.net/maindb?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Redis (used for backend query caching)
# Only enable Redis caching if you set this (otherwise caching is disabled to avoid stalling).
REDIS_URL=redis://localhost:6379
# Must be set to true to enable Redis caching.
REDIS_CACHE_ENABLED=false
# Optional: set to true to explicitly disable Redis caching.
REDIS_DISABLED=false
