## Frontend environment variables (Vite)
#
# Local development:
# - Leave `VITE_API_BASE_URL` empty to use the dev proxy (`/api` -> http://localhost:3026)
# - Or set it to call backend directly.
#
# Production (Hostinger VPS):
# - Set this to your backend base including `/api`
#   Example: https://dashbackend.thrivebrands.ai/api
#
VITE_API_BASE_URL=https://dashbackend.thrivebrands.ai/

